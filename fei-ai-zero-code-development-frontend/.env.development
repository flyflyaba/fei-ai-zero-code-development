# ============================================
# 开发环境配置
# ============================================

# API 请求前缀（开发时走 Vite 代理，避免跨域）
VITE_API_BASE_URL=/api

# 后端服务地址（Vite 代理目标）
VITE_PROXY_TARGET=http://localhost:8123

# 静态资源部署后的访问基础 URL
VITE_STATIC_BASE_URL=/api/static

# 应用标题
VITE_APP_TITLE=飞 AI 零代码开发平台