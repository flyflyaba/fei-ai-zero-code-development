# ============================================
# 开发环境配置
# ============================================

# API 请求地址（开发时走 Vite 代理，避免跨域）
VITE_API_BASE_URL=/api

# 后端服务地址（Vite 代理目标）
VITE_PROXY_TARGET=http://localhost:8123

# 应用部署域名（部署后的应用访问域名）
VITE_DEPLOY_DOMAIN=http://localhost

# 应用标题
VITE_APP_TITLE=飞 AI 零代码开发平台